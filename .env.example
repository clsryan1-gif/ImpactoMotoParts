# Exemplo de variáveis de ambiente para o projeto
# Copie este arquivo para .env e preencha com suas credenciais

# String de conexão com o Supabase (usando Transaction Pooling porta 6543)
# Quando usar Pooling, é OBRIGATÓRIO incluir ?pgbouncer=true no final
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:6543/postgres?pgbouncer=true"

# String de conexão direta (porta 5432) usada para migrações Prisma
DIRECT_URL="postgresql://USUARIO:SENHA@HOST:5432/postgres"

# Outras variáveis (Exemplo: NextAuth)
NEXTAUTH_SECRET="sua_chave_secreta"
NEXTAUTH_URL="http://localhost:3000"
